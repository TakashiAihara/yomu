{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "jest/require-to-throw-message": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": ["**/dist/", "**/node_modules/"]
}
